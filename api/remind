const SUPABASE_URL = process.env.SUPABASE_URL;
const SUPABASE_KEY = process.env.SUPABASE_KEY;
const TWILIO_SID = process.env.TWILIO_SID;
const TWILIO_TOKEN = process.env.TWILIO_TOKEN;
const TWILIO_FROM = process.env.TWILIO_FROM;

async function supabase(path, method = 'GET', body = null) {
  const res = await fetch(`${SUPABASE_URL}/rest/v1${path}`, {
    method,
    headers: {
      'apikey': SUPABASE_KEY,
      'Authorization': `Bearer ${SUPABASE_KEY}`,
      'Content-Type': 'application/json',
      'Prefer': method === 'POST' ? 'return=representation' : 'return=minimal'
    },
    body: body ? JSON.stringify(body) : null
  });
  if (!res.ok && res.status !== 204) {
    const err = await res.text();
    throw new Error(`Supabase error: ${err}`);
  }
  if (res.status === 204) return null;
  return res.json();
}

async function makeCall(phone, name, service, time, salonName, sid, token, from) {
  const twiml = `<Response><Say voice="alice">Hello ${name}, this is a reminder from ${salonName}. You have a ${service} appointment tomorrow at ${time}. Please call us if you need to reschedule. Thank you!</Say></Response>`;
  const params = new URLSearchParams({ To: phone, From: from, Twiml: twiml, Timeout: '30' });
  const res = await fetch(`https://api.twilio.com/2010-04-01/Accounts/${sid}/Calls.json`, {
    method: 'POST',
    headers: {
      'Authorization': 'Basic ' + Buffer.from(`${sid}:${token}`).toString('base64'),
      'Content-Type': 'application/x-www-form-urlencoded'
    },
    body: params
  });
  const data = await res.json();
  return data;
}

async function sendSMS(phone, message, sid, token, from) {
  const params = new URLSearchParams({ To: phone, From: from, Body: message });
  const res = await fetch(`https://api.twilio.com/2010-04-01/Accounts/${sid}/Messages.json`, {
    method: 'POST',
    headers: {
      'Authorization': 'Basic ' + Buffer.from(`${sid}:${token}`).toString('base64'),
      'Content-Type': 'application/x-www-form-urlencoded'
    },
    body: params
  });
  return res.json();
}

export default async function handler(req, res) {
  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' });

  const { action, ...data } = req.body;

  try {
    if (action === 'call') {
      const { appointmentId, phone, name, service, time, salonName, twilioSid, twilioToken, twilioFrom } = data;
      const sid = twilioSid || TWILIO_SID;
      const token = twilioToken || TWILIO_TOKEN;
      const from = twilioFrom || TWILIO_FROM;

      if (!sid || !token || !from) {
        return res.status(400).json({ error: 'Twilio not configured' });
      }

      const call = await makeCall(phone, name, service, time, salonName, sid, token, from);

      if (call.sid) {
        // Update appointment status in Supabase
        await supabase(`/appointments?id=eq.${appointmentId}`, 'PATCH', {
          status: 'calling',
          call_sid: call.sid,
          reminder_sent: true
        });
        return res.status(200).json({ success: true, callSid: call.sid });
      } else {
        // Call failed, send SMS
        const smsMsg = `Hi ${name}, reminder: your ${service} appointment is tomorrow at ${time}. Reply YES to confirm or NO to cancel.`;
        await sendSMS(phone, smsMsg, sid, token, from);
        await supabase(`/appointments?id=eq.${appointmentId}`, 'PATCH', { status: 'sms-sent', reminder_sent: true });
        return res.status(200).json({ success: true, action: 'sms_fallback' });
      }
    }

    if (action === 'sms') {
      const { appointmentId, phone, message, twilioSid, twilioToken, twilioFrom } = data;
      const sid = twilioSid || TWILIO_SID;
      const token = twilioToken || TWILIO_TOKEN;
      const from = twilioFrom || TWILIO_FROM;
      const sms = await sendSMS(phone, message, sid, token, from);
      if (sms.sid) {
        await supabase(`/appointments?id=eq.${appointmentId}`, 'PATCH', { status: 'sms-sent' });
        return res.status(200).json({ success: true, smsSid: sms.sid });
      }
      return res.status(500).json({ error: 'SMS failed', details: sms });
    }

    return res.status(400).json({ error: 'Unknown action' });
  } catch (err) {
    return res.status(500).json({ error: err.message });
  }
}
